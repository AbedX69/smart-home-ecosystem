# Zigbee device role (change for coordinator/router)
# ZB_ED_ROLE   = End Device (light, sensor)
# ZB_ZCZR_ROLE = Coordinator or Router
CONFIG_ZB_ENABLED=y
CONFIG_ZB_ZED=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Recommended: disable idle task WDT for Zigbee (stack can be slow)
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
